{
  "name": "cursor-distill",
  "version": "0.2.0",
  "description": "Automatically distill your Cursor agent transcripts into rules, skills, and subagents",
  "author": "Aiden Hadisi <aiden@hadisi.com> (https://github.com/AidenHadisi)",
  "license": "MIT",
  "homepage": "https://github.com/AidenHadisi/cursor-distill#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/AidenHadisi/cursor-distill.git"
  },
  "bugs": {
    "url": "https://github.com/AidenHadisi/cursor-distill/issues"
  },
  "type": "module",
  "bin": {
    "cursor-distill": "dist/cli.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "start": "node dist/cli.js",
    "test": "tsc && node --test dist/test/*.test.js",
    "prepublishOnly": "npm run build"
  },
  "files": [
    "dist",
    "!dist/test"
  ],
  "keywords": [
    "cursor",
    "cursor-ide",
    "ai",
    "agent",
    "rules",
    "skills",
    "subagents",
    "transcripts",
    "automation",
    "cli"
  ],
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "commander": "^13.1.0",
    "ora": "^9.4.1",
    "picocolors": "^1.1.1"
  },
  "devDependencies": {
    "@types/node": "^22.15.0",
    "typescript": "^5.8.0"
  }
}
